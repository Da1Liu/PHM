# PHM 中心侧 PostgreSQL 连接 — 复制本文件为 .env 并填入真实口令。
# .env 已被 .gitignore 排除, 不会进版本库。环境变量若已设置则覆盖此处 (环境变量优先)。
# 由 phm_pipeline/db_config.py::default_db() 读取 (看板/评分/采集桥共用)。

PHM_PGPASSWORD=请在此填入数据库口令
# 以下均有默认值, 按需覆盖:
# PHM_PGHOST=localhost
# PHM_PGPORT=5432
# PHM_PGUSER=postgres
# PHM_PGDATABASE=vibration_db
