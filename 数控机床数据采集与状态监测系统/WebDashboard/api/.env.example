# PostgreSQL 连接。复制本文件为 .env，并填入现场真实值。
PGHOST=localhost
PGPORT=5432
PGDATABASE=vibration_db
PGUSER=postgres
PGPASSWORD=CHANGE_ME

# API 监听端口
PORT=4000

# 单次趋势查询返回的最大点数（数据库侧降采样目标）
MAX_POINTS=1000

# ---- OPC UA 轮询服务（替代桌面端 Form2 的三个 1s Timer）----
# 是否随后端启动轮询
OPCUA_ENABLED=false
# 地址 profile：kepserver=KEPServer 标签名 / machine=真实机床 Siemens 地址
#   （两套均迁移自 GlobalVariables.cs；节点细节见 src/opcua/config.js）
OPCUA_PROFILE=kepserver
# OPC UA Server 地址。现场 KEPServer 例：opc.tcp://<工控机名或IP>:49320
#   真实机床（machine profile）例：opc.tcp://172.16.81.1:4840
OPCUA_ENDPOINT=opc.tcp://localhost:49320
# 是否匿名登录（测试 server 用 true；真实服务器用 false 并填账号密码）
OPCUA_ANONYMOUS=true
OPCUA_USER=CHANGE_ME
OPCUA_PASSWORD=CHANGE_ME
# 轮询间隔（ms），对应桌面端 1000ms
OPCUA_POLL_MS=1000

